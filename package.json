{
  "name": "perpetual-engine",
  "version": "0.3.0",
  "description": "AI 에이전트 스타트업 프레임워크 - 토큰만 투자하면 AI가 사업을 만든다",
  "type": "module",
  "bin": {
    "perpetual-engine": "./dist/bin/cli.js"
  },
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "scripts": {
    "build": "tsc && npm run build:assets",
    "build:assets": "mkdir -p dist/src/dashboard/client dist/src/dashboard/design && cp -R src/dashboard/client/dist dist/src/dashboard/client/ && cp -R src/dashboard/design/. dist/src/dashboard/design/",
    "postinstall": "node scripts/postinstall.mjs",
    "dev": "tsx bin/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:e2e": "vitest run tests/e2e",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "ai",
    "agent",
    "startup",
    "framework",
    "claude",
    "multi-agent"
  ],
  "author": "PerpetualEngine",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/greatsk55/perpetual-engine.git"
  },
  "homepage": "https://github.com/greatsk55/perpetual-engine#readme",
  "bugs": {
    "url": "https://github.com/greatsk55/perpetual-engine/issues"
  },
  "files": [
    "dist",
    "scripts",
    "bin",
    "README.md",
    "README.ko.md",
    "LICENSE"
  ],
  "dependencies": {
    "@inquirer/prompts": "^7.0.0",
    "chalk": "^5.4.0",
    "chokidar": "^4.0.0",
    "cli-table3": "^0.6.5",
    "commander": "^13.0.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "nanoid": "^5.0.0",
    "ws": "^8.20.0",
    "yaml": "^2.6.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
